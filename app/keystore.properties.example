# Copy this file to app/keystore.properties and fill with your real values.
# Do NOT commit app/keystore.properties to git.
# Safer option: keep passwords in environment variables and leave only storeFile here.
# Env vars supported:
#   LM_STORE_FILE
#   LM_STORE_PASSWORD
#   LM_KEY_ALIAS
#   LM_KEY_PASSWORD

# Absolute path to your keystore file (Windows example)
storeFile=C:/path/to/your/release.keystore

# Keystore password
storePassword=your_store_password

# Key alias
keyAlias=your_key_alias

# Key password
keyPassword=your_key_password
